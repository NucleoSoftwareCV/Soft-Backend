# Copia este archivo como .env para desarrollo local.
POSTGRES_DB=OonaDB
POSTGRES_USER=oona_user
POSTGRES_PASSWORD=change-me-local-password

DB_URL=jdbc:postgresql://localhost:5432/OonaDB
DB_USERNAME=oona_user
DB_PASSWORD=change-me-local-password

JWT_SECRET=change-me-to-a-long-random-secret-with-at-least-32-characters
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

SPRING_JPA_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
