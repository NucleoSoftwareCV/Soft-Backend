POSTGRES_DB=OonaDB
POSTGRES_USER=oona_user
POSTGRES_PASSWORD=replace-with-production-secret

JWT_SECRET=replace-with-production-secret-at-least-32-characters
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000
APP_FIELD_ENCRYPTION_KEY=replace-with-production-field-encryption-key

SPRING_JPA_DDL_AUTO=validate
SPRING_FLYWAY_BASELINE_ON_MIGRATE=false
APP_PORT=8083
OONA_API_IMAGE=oona-api:latest
